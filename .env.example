# Smart Disaster Command Center — Environment Variables
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ============================================================
# PRIMARY AI: Gemini 2.5 Flash (Round-Robin, Tier 1)
# Get keys from: https://aistudio.google.com/app/apikey
# ============================================================
GEMINI_API_KEY1=AIzaSy_replace_with_key_1
GEMINI_API_KEY2=AIzaSy_replace_with_key_2
GEMINI_API_KEY3=AIzaSy_replace_with_key_3
GEMINI_API_KEY4=AIzaSy_replace_with_key_4
GEMINI_API_KEY5=AIzaSy_replace_with_key_5

# ============================================================
# FALLBACK AI: Qwen 2.5 7B via HuggingFace Inference API (Tier 2)
# Provider: together (serverless, no GPU required)
# Get token from: https://huggingface.co/settings/tokens
# ============================================================
HF_TOKEN=hf_replace_with_your_token

# ============================================================
# CORS — Frontend URL (used in production)
# Set this to your Vercel deployment URL, e.g.:
#   FRONTEND_URL=https://your-app.vercel.app
# Leave empty for local development (localhost is always allowed)
# ============================================================
FRONTEND_URL=

# ============================================================
# SYSTEM (optional, recommended for production)
# ============================================================
PYTHONIOENCODING=utf-8
PYTHONUNBUFFERED=1
